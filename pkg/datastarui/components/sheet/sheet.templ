package sheet

import "github.com/CoreyCole/vamos/pkg/datastarui/utils"

// SheetSignals defines the signal structure for sheet components
type SheetSignals struct {
	Open        bool        `json:"open"`
	Modal       bool        `json:"modal"`
	ReturnValue interface{} `json:"returnValue"`
}

// Sheet container - can be modal or non-modal based on configuration
templ Sheet(args SheetArgs) {
	{{
		// Create signals using the structured system with proper initial state
		signals := utils.Signals(args.ID, SheetSignals{
			Open:        args.DefaultOpen,
			Modal:       args.Modal,
			ReturnValue: nil,
		})

		// Sheet backdrop overlay - only shown for modal sheets
		backdropClasses := "fixed inset-0 z-50 bg-black/50 transition-opacity duration-300 data-[state=closed]:opacity-0 data-[state=open]:opacity-100"

		// Sheet positioning classes based on side
		var sheetClasses string
		var zIndex string
		if args.Modal {
			zIndex = "z-50" // Modal sheets on top
		} else {
			zIndex = "z-40" // Non-modal sheets below modals
		}
		baseSheetClasses := "fixed gap-4 bg-background p-6 shadow-lg transition-opacity duration-300 " + zIndex

		switch args.Side {
		case "top":
			sheetClasses = baseSheetClasses + " inset-x-0 top-0 border-b"
		case "bottom":
			sheetClasses = baseSheetClasses + " inset-x-0 bottom-0 border-t"
		case "left":
			sheetClasses = baseSheetClasses + " inset-y-0 left-0 h-full w-3/4 border-r sm:max-w-sm"
		default: // "right"
			sheetClasses = baseSheetClasses + " inset-y-0 right-0 h-full w-3/4 border-l sm:max-w-sm"
		}
		
		// Create data-class expressions for fade animations
		backdropDataClass := utils.NewDataClass().
			Add("opacity-0", "!"+signals.Signal("open")).
			Add("opacity-100", signals.Signal("open")).
			Build()
		sheetDataClass := utils.NewDataClass().
			Add("opacity-0", "!"+signals.Signal("open")).
			Add("opacity-100", signals.Signal("open")).
			Build()

		// Create sheet handler for clean expressions
		sheetHandler := NewSheetHandler(signals)
		escapeHandler := sheetHandler.BuildEscapeHandler()

		// For modal sheets, clicking backdrop closes the sheet
		// For non-modal sheets, backdrop click is ignored
		var backdropClickHandler string
		if args.Modal {
			backdropClickHandler = sheetHandler.BuildBackdropClickHandler()
		} else {
			backdropClickHandler = ""
		}
	}}
	<div data-signals={ signals.DataSignals }>
		if args.Modal {
			<!-- Modal backdrop overlay -->
			<div
				data-show={ signals.Signal("open") }
				class={ backdropClasses }
				data-class={ backdropDataClass }
				data-on:click={ backdropClickHandler }
				if !args.DefaultOpen {
					style="display: none;"
				}
			></div>
		}
		<!-- Sheet content container -->
		<div
			id={ args.ID }
			data-show={ signals.Signal("open") }
			class={ sheetClasses }
			data-class={ sheetDataClass }
			role="dialog"
			if args.Modal {
				aria-modal="true"
			}
			tabindex="-1"
			data-on:keydown__window={ escapeHandler }
			data-on:mount="evt.target.focus()"
			if !args.DefaultOpen {
				style="display: none;"
			}
			{ args.Attributes... }
		>
			{ children... }
		</div>
	</div>
}

// SheetTrigger - button or element that opens the sheet using Datastar signals
templ SheetTrigger(args SheetTriggerArgs) {
	{{
		// Create signals manager for the target sheet
		signals := utils.Signals(args.SheetID, SheetSignals{})
		clickHandler := signals.Set("open", "true")
	}}
	if args.AsChild {
		// When AsChild is true, we apply the click handler to the child element
		<div
			data-on:click={ clickHandler }
			{ args.Attributes... }
			class={ args.Class }
		>
			{ children... }
		</div>
	} else {
		<button
			type="button"
			data-on:click={ clickHandler }
			{ args.Attributes... }
			class={ args.Class }
		>
			{ children... }
		</button>
	}
}

// SheetContent - content wrapper for the sheet
templ SheetContent(args SheetContentArgs) {
	{{
		// Generate the CSS classes using our variant system
		classes := SheetContentVariants(args)
	}}
	<div
		data-slot="sheet-content"
		class={ classes }
		{ args.Attributes... }
	>
		<div class="flex flex-row justify-end mb-4">
			@SheetClose(SheetCloseArgs{
				SheetID: args.SheetID,
				Class:   "rounded-sm opacity-70 ring-offset-background transition-opacity hover:opacity-100 focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 disabled:pointer-events-none data-[state=open]:bg-secondary w-6 h-6 flex items-center justify-center shrink-0",
			})
		</div>
		{ children... }
	</div>
}

