// SheetClose - button that closes the sheet using Datastar signals
templ SheetClose(args SheetCloseArgs) {
	{{
		// Create signals manager for the target sheet
		signals := utils.Signals(args.SheetID, SheetSignals{})

		// Create sheet handler for clean expressions
		sheetHandler := NewSheetHandler(signals)
		clickHandler := sheetHandler.BuildCloseHandler(args.ReturnValue)

		// Use X icon for close button
		iconClasses := "h-4 w-4"
	}}
	if args.AsChild {
		<div
			data-on:click={ clickHandler }
			{ args.Attributes... }
			class={ args.Class }
		>
			{ children... }
		</div>
	} else {
		<button
			type="button"
			data-on:click={ clickHandler }
			{ args.Attributes... }
			class={ args.Class }
		>
			{ children... }
			<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={ iconClasses }>
				<path d="M18 6 6 18"></path>
				<path d="m6 6 12 12"></path>
			</svg>
			<span class="sr-only">Close</span>
		</button>
	}
}
