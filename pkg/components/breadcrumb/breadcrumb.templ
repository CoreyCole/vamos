package breadcrumb

// Breadcrumb renders the main navigation wrapper
templ Breadcrumb(args BreadcrumbArgs) {
	<nav
		aria-label="breadcrumb"
		data-slot="breadcrumb"
		class={ breadcrumbVariants(args.Class) }
		{ args.Attributes... }
	>
		{ children... }
	</nav>
}

// BreadcrumbList renders the ordered list container for breadcrumb items
templ BreadcrumbList(args BreadcrumbListArgs) {
	<ol
		data-slot="breadcrumb-list"
		class={ breadcrumbListVariants(args.Class) }
		{ args.Attributes... }
	>
		{ children... }
	</ol>
}

// BreadcrumbItem renders a list item wrapper for breadcrumb content
templ BreadcrumbItem(args BreadcrumbItemArgs) {
	<li
		data-slot="breadcrumb-item"
		class={ breadcrumbItemVariants(args.Class) }
		{ args.Attributes... }
	>
		{ children... }
	</li>
}

// BreadcrumbLink renders a clickable breadcrumb link
templ BreadcrumbLink(args BreadcrumbLinkArgs) {
	if args.AsChild {
		<span
			data-slot="breadcrumb-link"
			class={ breadcrumbLinkVariants(args.Class) }
			{ args.Attributes... }
		>
			{ children... }
		</span>
	} else {
		<a
			data-slot="breadcrumb-link"
			href={ templ.SafeURL(args.Href) }
			class={ breadcrumbLinkVariants(args.Class) }
			{ args.Attributes... }
		>
			{ children... }
		</a>
	}
}

// BreadcrumbPage renders the current page indicator (non-clickable)
templ BreadcrumbPage(args BreadcrumbPageArgs) {
	<span
		data-slot="breadcrumb-page"
		role="link"
		aria-disabled="true"
		aria-current="page"
		class={ breadcrumbPageVariants(args.Class) }
		{ args.Attributes... }
	>
		{ children... }
	</span>
}

// BreadcrumbSeparator renders the separator between breadcrumb items
templ BreadcrumbSeparator(args BreadcrumbSeparatorArgs) {
	<li
		data-slot="breadcrumb-separator"
		role="presentation"
		aria-hidden="true"
		class={ breadcrumbSeparatorVariants(args.Class) }
		{ args.Attributes... }
	>
		if args.CustomIcon {
			{ children... }
		} else {
			<!-- ChevronRight icon (default separator) -->
			<svg
				class="size-3.5"
				fill="none"
				stroke="currentColor"
				viewBox="0 0 24 24"
				xmlns="http://www.w3.org/2000/svg"
			>
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m9 18 6-6-6-6"></path>
			</svg>
		}
	</li>
}

// BreadcrumbEllipsis renders an ellipsis indicator for collapsed breadcrumbs
templ BreadcrumbEllipsis(args BreadcrumbEllipsisArgs) {
	<span
		data-slot="breadcrumb-ellipsis"
		role="presentation"
		aria-hidden="true"
		class={ breadcrumbEllipsisVariants(args.Class) }
		{ args.Attributes... }
	>
		<!-- MoreHorizontal icon -->
		<svg
			class="size-4"
			fill="none"
			stroke="currentColor"
			viewBox="0 0 24 24"
			xmlns="http://www.w3.org/2000/svg"
		>
			<circle cx="12" cy="12" r="1"></circle>
			<circle cx="19" cy="12" r="1"></circle>
			<circle cx="5" cy="12" r="1"></circle>
		</svg>
		<span class="sr-only">More</span>
	</span>
}
