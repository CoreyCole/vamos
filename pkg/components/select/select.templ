package selectcomponent 

import (
	"crypto/rand"
	"fmt"
	"github.com/CoreyCole/vamos/pkg/components/utils"
	"strings"
)

// SelectSignals defines the signal structure for select components
type SelectSignals struct {
	Open        bool   `json:"open"`
	Value       string `json:"value"`
	Label       string `json:"label"`
	Highlighted int    `json:"highlighted"` // Index of currently highlighted item (-1 = none)
}

// Select renders the main select wrapper with Datastar state management
// If Options are provided, it will automatically render the complete select UI
templ Select(args SelectArgs) {
	{{
		// Generate unique ID if not provided (following dropdown pattern exactly)
		selectID := args.ID
		if selectID == "" {
			// Generate a random ID
			b := make([]byte, 4)
			rand.Read(b)
			selectID = fmt.Sprintf("select_%x", b)
		}

		openState := false
		if args.DefaultOpen || args.Open {
			openState = true
		}

		// Determine initial value
		initialValue := args.Value
		if initialValue == "" {
			initialValue = args.DefaultValue
		}

		// Find initial label if value is set and options are provided
		initialLabel := ""
		if initialValue != "" && len(args.Options) > 0 {
			for _, option := range args.Options {
				if option.Value == initialValue {
					initialLabel = option.Label
					break
				}
			}
		}

		// Create signals using the new structured system
		signals := utils.Signals(selectID, SelectSignals{
			Open:        openState,
			Value:       initialValue,
			Label:       initialLabel, // Set initial label if found
			Highlighted: -1,           // No item highlighted initially
		})

		// Click outside handler - use conditional pattern from Datastar docs
		clickOutsideHandler := signals.Signal("open") + " ? " + signals.Set("open", "false") + " : null"

		// Create a data-effect handler that watches for value changes
		effectHandler := ""
		if args.OnChange != "" {
			// Only execute OnChange when value actually changes (not on initial load or other signal changes)
			effectHandler = fmt.Sprintf(
				"if ($%s.value && $%s.value !== $%s._lastValue) { $%s._lastValue = $%s.value; %s }",
				selectID, selectID, selectID, selectID, selectID, args.OnChange,
			)
		}
	}}
	<div
		data-slot="select"
		data-select-id={ selectID }
		data-signals={ signals.DataSignals }
		if effectHandler != "" {
			data-effect={ effectHandler }
		}
		data-on:click__outside={ clickOutsideHandler }
		class={ selectVariants(args.Class) }
		{ args.Attributes... }
	>
		if args.Name != "" {
			<!-- Hidden input for form submission -->
			<input
				type="hidden"
				name={ args.Name }
				data-bind={ signals.Signal("value") }
				if args.Required {
					required
				}
			/>
		}
		if args.Options != nil {
			<!-- Auto-render complete select UI when Options slice is set (even if empty) -->
			@SelectTrigger(SelectTriggerArgs{
				ID:       selectID,
				Disabled: args.Disabled || len(args.Options) == 0,
			}) {
				@SelectValue(SelectValueArgs{
					ID:          selectID,
					Placeholder: args.Placeholder,
				})
			}
			if len(args.Options) > 0 {
				@SelectContent(SelectContentArgs{
					ID: selectID,
				}) {
					@renderSelectOptions(selectID, args.Options)
				}
			}
		} else {
			<!-- Manual composition when Options is nil -->
			{ children... }
		}
	</div>
}

// renderSelectOptions renders a slice of SelectOptions with proper grouping
templ renderSelectOptions(selectID string, options []SelectOptionArgs) {
	{{
		// Group options by their Group field
		groupedOptions := make(map[string][]SelectOptionArgs)
		ungroupedOptions := []SelectOptionArgs{}

		for _, option := range options {
			if option.Group != "" {
				groupedOptions[option.Group] = append(groupedOptions[option.Group], option)
			} else {
				ungroupedOptions = append(ungroupedOptions, option)
			}
		}

		// Calculate global index for keyboard navigation
		globalIndex := 0
	}}
	<!-- Render ungrouped options first -->
	if len(ungroupedOptions) > 0 {
		for _, option := range ungroupedOptions {
			@SelectItem(SelectItemArgs{
				ID:       selectID,
				Value:    option.Value,
				Index:    globalIndex,
				Disabled: option.Disabled,
			}) {
				{ option.Label }
			}
			{{ globalIndex++ }}
		}
	}
	<!-- Render grouped options -->
	for groupName, groupOptions := range groupedOptions {
		if len(ungroupedOptions) > 0 || groupName != "" {
			@SelectSeparator(SelectSeparatorArgs{})
		}
		@SelectGroup(SelectGroupArgs{}) {
			if groupName != "" {
				@SelectLabel(SelectLabelArgs{}) {
					{ groupName }
				}
			}
			for _, option := range groupOptions {
				@SelectItem(SelectItemArgs{
					ID:       selectID,
					Value:    option.Value,
					Index:    globalIndex,
					Disabled: option.Disabled,
				}) {
					{ option.Label }
				}
				{{ globalIndex++ }}
			}
		}
	}
}

// SelectTrigger - button that opens/closes the select dropdown
templ SelectTrigger(args SelectTriggerArgs) {
	{{
		// Create signals manager for this select
		signals := utils.Signals(args.ID, SelectSignals{})

		// Generate the CSS classes using our variant system
		classes := selectTriggerVariants(args.Class)

		// Generate trigger handlers using expression builder
		triggerHandler := NewSelectTriggerHandler(args.ID, signals)
		clickExpr := triggerHandler.BuildClickHandler()
		triggerKeyHandler := triggerHandler.BuildKeyboardHandler()
	}}
	<button
		data-slot="select-trigger"
		type="button"
		role="combobox"
		data-attr:aria-expanded={ signals.Signal("open") }
		class={ classes }
		disabled?={ args.Disabled }
		data-on:click={ clickExpr }
		data-on:keydown={ triggerKeyHandler }
		{ args.Attributes... }
	>
		{ children... }
		<!-- ChevronDown icon -->
		<svg
			class="h-4 w-4 opacity-50 shrink-0"
			xmlns="http://www.w3.org/2000/svg"
			width="24"
			height="24"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
		>
			<path d="m6 9 6 6 6-6"></path>
		</svg>
	</button>
}

// SelectValue displays the currently selected value or placeholder
templ SelectValue(args SelectValueArgs) {
	{{
		// Build the label signal reference manually
		labelSignal := "$" + args.ID + ".label"

		escapedDefault := strings.ReplaceAll(args.Placeholder, "'", "\\'")
		displayText := fmt.Sprintf("%s || '%s'", labelSignal, escapedDefault)
	}}
	<span
		data-slot="select-value"
		class="pointer-events-none truncate"
		data-text={ displayText }
		{ args.Attributes... }
	>
		if args.Placeholder != "" {
			{ args.Placeholder }
		}
	</span>
}

// SelectContent - dropdown content container
templ SelectContent(args SelectContentArgs) {
	{{
		// Create signals manager for this select
		signals := utils.Signals(args.ID, SelectSignals{})

		// Generate the CSS classes using our variant system
		classes := selectContentVariants(args.Position, args.Class)

		// Create expressions
		showExpr := signals.Signal("open")

		// Generate content keyboard navigation using expression builder
		contentHandler := NewSelectContentHandler(args.ID, signals)
		keyHandler := contentHandler.BuildKeyboardHandler()

		// Generate viewport classes
		viewportClasses := selectViewportVariants(args.Position, "")
	}}
	<div
		data-slot="select-content"
		class={ classes }
		data-show={ showExpr }
		data-on:keydown__window={ keyHandler }
		role="listbox"
		tabindex="-1"
		style="position: absolute; top: 100%; left: 0; right: 0; z-index: 50; display: none;"
		{ args.Attributes... }
	>
		<div class={ viewportClasses }>
			{ children... }
		</div>
	</div>
}

// SelectItem - individual option in the select dropdown
templ SelectItem(args SelectItemArgs) {
	{{
		// Create signals manager for this select
		signals := utils.Signals(args.ID, SelectSignals{})

		// Generate the CSS classes using our variant system
		classes := selectItemVariants(args.Class)

		// Generate item selection handlers using expression builder
		itemHandler := NewSelectItemHandler(args.ID, args.Value)
		selectExpr := itemHandler.BuildClickHandler()
		itemKeyHandler := itemHandler.BuildKeyboardHandler()

		// Add highlighted class conditionally using data-class helper
		highlightedClass := highlightedItem(fmt.Sprintf("%s.highlighted", args.ID), args.Index)
	}}
	<div
		data-slot="select-item"
		data-select-item
		class={ classes }
		data-class={ highlightedClass }
		role="option"
		data-value={ args.Value }
		data-index={ fmt.Sprintf("%d", args.Index) }
		tabindex="0"
		if !args.Disabled {
			data-on:click={ selectExpr }
			data-on:keydown={ itemKeyHandler }
		}
		if args.Disabled {
			data-disabled="true"
		}
		{ args.Attributes... }
	>
		<span class="absolute right-2 flex h-3.5 w-3.5 items-center justify-center">
			<!-- Check icon for selected state -->
			<svg
				class="h-4 w-4"
				data-show={ signals.Equals("value", args.Value) }
				xmlns="http://www.w3.org/2000/svg"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
			>
				<path d="M20 6 9 17l-5-5"></path>
			</svg>
		</span>
		<span class="select-item-text truncate">
			{ children... }
		</span>
	</div>
}

// SelectLabel renders a label for a group of items
templ SelectLabel(args SelectLabelArgs) {
	{{
		classes := selectLabelVariants(args.Class)
	}}
	<div
		data-slot="select-label"
		class={ classes }
		{ args.Attributes... }
	>
		{ children... }
	</div>
}

// SelectSeparator renders a visual separator between groups
templ SelectSeparator(args SelectSeparatorArgs) {
	{{
		classes := selectSeparatorVariants(args.Class)
	}}
	<div
		data-slot="select-separator"
		class={ classes }
		{ args.Attributes... }
	></div>
}

// SelectGroup renders a group container for items
templ SelectGroup(args SelectGroupArgs) {
	<div
		data-slot="select-group"
		role="group"
		class={ args.Class }
		{ args.Attributes... }
	>
		{ children... }
	</div>
}
