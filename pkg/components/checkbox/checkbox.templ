package checkbox

import "github.com/CoreyCole/vamos/pkg/components/utils"

// CheckboxSignals defines the signal structure for checkbox components
type CheckboxSignals struct {
	Checked  bool `json:"checked"`
	Disabled bool `json:"disabled"`
}

// Checkbox renders a checkbox input with shadcn/ui styling and internal Datastar reactivity
templ Checkbox(args CheckboxArgs) {
	{{
		// Create signals using the new structured system
		signals := utils.Signals(args.ID, CheckboxSignals{
			Checked:  args.Checked,
			Disabled: args.Disabled,
		})

		// Generate the CSS classes using the variant system
		classes := checkboxVariants(args.ClassName)

		// Create signal expressions
		signalRef := signals.Signal("checked")
		// Only toggle if not disabled
		toggleExpr := utils.BuildConditional(
			"!" + signals.Signal("disabled"),
			signals.Toggle("checked"),
			"null",
		)

		// Create data-class for disabled styling
		dataClass := utils.NewDataClass().
			Add("cursor-not-allowed opacity-50", signals.Signal("disabled")).
			Build()

		// Combine classes
		allClasses := classes
		if args.ClassName != "" {
			allClasses += " " + args.ClassName
		}
	}}
	<div data-signals={ signals.DataSignals }>
		<button
			type="button"
			id={ args.ID }
			class={ allClasses }
			data-class={ dataClass }
			role="checkbox"
			data-on:click={ toggleExpr }
			data-attr:aria-checked={ signals.Conditional("checked", "'true'", "'false'") }
			data-attr:data-state={ signals.Conditional("checked", "'checked'", "'unchecked'") }
			data-attr:disabled={ signals.Signal("disabled") }
			data-attr:aria-disabled={ signals.Signal("disabled") }
			{ args.Attributes... }
		>
			<!-- Checkmark icon -->
			<svg
				xmlns="http://www.w3.org/2000/svg"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				class="h-4 w-4"
				data-attr:style={ signals.TernaryStyle("checked", "opacity: 1", "opacity: 0") }
			>
				<path d="M20 6 9 17l-5-5"></path>
			</svg>
		</button>
		<!-- Hidden input for form submission -->
		<input
			type="checkbox"
			name={ args.Name }
			class="sr-only"
			data-attr:checked={ signalRef }
			data-attr:value={ signals.Conditional("checked", "'true'", "'false'") }
			data-attr:disabled={ signals.Signal("disabled") }
			tabindex="-1"
		/>
	</div>
}

// CheckboxIndicator renders the checkbox indicator (check mark)
templ CheckboxIndicator(args CheckboxIndicatorArgs) {
	<span
		data-slot="checkbox-indicator"
		class={ checkboxIndicatorVariants(args.ClassName) }
		{ args.Attributes... }
	>
		{ children... }
	</span>
}
