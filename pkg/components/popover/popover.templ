package popover

import "github.com/CoreyCole/vamos/pkg/components/utils"

// PopoverTrigger creates a trigger for the popover that wraps any element
templ PopoverTrigger(args PopoverTriggerArgs) {
	{{
		// Create popover handler for clean expressions
		popoverHandler := NewPopoverHandler(args.PopoverID)
		toggleHandler := popoverHandler.BuildToggleHandler()
		
		// Use PopoverID as anchor name (shared with content)
		anchorStyle := popoverHandler.BuildAnchorStyle(args.PopoverID)

		// Build style attribute
		style := "cursor: pointer;"
		if anchorStyle != "" {
			style += " " + anchorStyle
		}
	}}
	<div
		id={ args.ID }
		data-on:click={ toggleHandler }
		if style != "" {
			style={ style }
		}
		class={ args.Class }
		{ args.Attributes... }
	>
		{ children... }
	</div>
}

// PopoverContent creates the popover content panel
templ PopoverContent(args PopoverContentArgs) {
	{{
		contentClasses := PopoverContentVariants(args)

		// Create popover handler for clean expressions
		popoverHandler := NewPopoverHandler(args.ID)

		// Generate positioning styles
		positioningStyle := ""

		if args.UseAnchor {
			// Use content ID as position anchor (matches trigger's PopoverID)
			positioningStyle = "position: absolute; " + popoverHandler.BuildPositionAnchorStyle(args.ID) + "; z-index: 50; "

			if args.Side != "" || args.Align != "" {
				sideOffset := args.SideOffset
				if sideOffset == 0 {
					sideOffset = 8 // default offset
				}
				anchorCSS := utils.GetAnchorPosition(args.Side, args.Align, sideOffset)
				positioningStyle += anchorCSS + ";"
			}
		} else {
			// Default positioning without anchor - still need position absolute for native popover + anchor positioning
			positioningStyle = "position: absolute; z-index: 50;"
		}

		// Add anchor-positioned class if using anchor positioning
		if args.UseAnchor {
			contentClasses += " anchor-positioned"
		}
	}}
	<div
		id={ args.ID }
		popover="auto"
		class={ contentClasses }
		style={ positioningStyle }
		{ args.Attributes... }
	>
		{ children... }
	</div>
}
