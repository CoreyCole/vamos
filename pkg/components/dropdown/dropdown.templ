package dropdown

import (
	"crypto/rand"
	"fmt"
	"github.com/CoreyCole/vamos/pkg/components/utils"
)

// DropdownSignals defines the signal structure for dropdown components
type DropdownSignals struct {
	Open bool `json:"open"`
}

// DropdownMenu renders the main dropdown wrapper with Datastar state management
templ DropdownMenu(args DropdownMenuArgs) {
	{{
		// Generate unique ID if not provided
		dropdownID := args.ID
		if dropdownID == "" {
			// Generate a random ID
			b := make([]byte, 4)
			rand.Read(b)
			dropdownID = fmt.Sprintf("dropdown_%x", b)
		}

		openState := false
		if args.DefaultOpen || args.Open {
			openState = true
		}

		// Create signals using the new structured system
		signals := utils.Signals(dropdownID, DropdownSignals{
			Open: openState,
		})

		// Click outside handler using expression builder
		dropdownHandler := newDropdownHandler(signals)
		clickOutsideHandler := dropdownHandler.buildClickOutsideHandler()
	}}
	<div
		data-slot="dropdown-menu"
		data-signals={ signals.DataSignals }
		data-on:click__outside={ clickOutsideHandler }
		class={ dropdownMenuVariants(args.Class) }
		{ args.Attributes... }
	>
		{ children... }
	</div>
}

// DropdownMenuTrigger renders the trigger button that opens/closes the dropdown
templ DropdownMenuTrigger(args DropdownMenuTriggerArgs) {
	{{
		// Create signals manager for this dropdown
		signals := utils.Signals(args.ID, DropdownSignals{})
		toggleExpr := signals.Toggle("open")
	}}
	if args.AsChild {
		<span
			data-slot="dropdown-menu-trigger"
			class={ dropdownMenuTriggerVariants(args.Class) }
			data-on:click={ toggleExpr }
			if args.Disabled {
				aria-disabled="true"
			}
			{ args.Attributes... }
		>
			{ children... }
		</span>
	} else {
		<button
			data-slot="dropdown-menu-trigger"
			type="button"
			class={ dropdownMenuTriggerVariants(args.Class) }
			data-on:click={ toggleExpr }
			disabled?={ args.Disabled }
			{ args.Attributes... }
		>
			{ children... }
		</button>
	}
}

// DropdownMenuContent renders the dropdown content panel
templ DropdownMenuContent(args DropdownMenuContentArgs) {
	{{
		// Calculate positioning classes based on args
		alignClass := ""
		switch args.Align {
		case "start":
			alignClass = "left-0"
		case "end":
			alignClass = "right-0"
		case "center":
			alignClass = "left-1/2 -translate-x-1/2"
		default:
			alignClass = "left-0"
		}

		// Generate positioning classes using expression builder helper
		sideClass := createSideClasses(args.Side, args.SideOffset)
		// Create signals manager for this dropdown
		signals := utils.Signals(args.ID, DropdownSignals{})
		showExpr := signals.Signal("open")

		// ESC key handler for closing dropdown using expression builder
		dropdownHandler := newDropdownHandler(signals)
		escapeHandler := dropdownHandler.buildEscapeHandler()
	}}
	<div
		data-slot="dropdown-menu-content"
		class={ utils.TwMerge(dropdownMenuContentVariants(args.Class), "absolute", sideClass, alignClass) }
		data-show={ showExpr }
		data-on:keydown__window={ escapeHandler }
		role="menu"
		style="display: none;"
		{ args.Attributes... }
	>
		{ children... }
	</div>
}

// DropdownMenuItem renders a clickable menu item
templ DropdownMenuItem(args DropdownMenuItemArgs) {
	{{
		// Create signals manager for this dropdown
		signals := utils.Signals(args.ID, DropdownSignals{})
		hideExpr := signals.Set("open", "false")
		// Combine hideExpr with custom OnClick if provided
		clickExpr := hideExpr
		if args.OnClick != "" {
			clickExpr = hideExpr + "; " + args.OnClick
		}
	}}
	if args.AsChild {
		<span
			data-slot="dropdown-menu-item"
			class={ dropdownMenuItemVariants(args.Variant, args.Class, args.Inset, args.Disabled) }
			role="menuitem"
			if args.Disabled {
				aria-disabled="true"
			}
			{ templ.Attributes(map[string]any{
				"data-inset": args.Inset,
				"data-variant": args.Variant,
				"data-disabled": args.Disabled,
			})... }
			{ args.Attributes... }
		>
			{ children... }
		</span>
	} else {
		<div
			data-slot="dropdown-menu-item"
			class={ dropdownMenuItemVariants(args.Variant, args.Class, args.Inset, args.Disabled) }
			role="menuitem"
			tabindex="0"
			data-on:click={ clickExpr }
			if args.Disabled {
				aria-disabled="true"
			}
			{ templ.Attributes(map[string]any{
				"data-inset": args.Inset,
				"data-variant": args.Variant,
				"data-disabled": args.Disabled,
			})... }
			{ args.Attributes... }
		>
			{ children... }
		</div>
	}
}

// DropdownMenuLabel renders a non-interactive label
templ DropdownMenuLabel(args DropdownMenuLabelArgs) {
	<div
		data-slot="dropdown-menu-label"
		class={ dropdownMenuLabelVariants(args.Class, args.Inset) }
		role="presentation"
		{ templ.Attributes(map[string]any{
			"data-inset": args.Inset,
		})... }
		{ args.Attributes... }
	>
		{ children... }
	</div>
}

// DropdownMenuSeparator renders a visual separator
templ DropdownMenuSeparator(args DropdownMenuSeparatorArgs) {
	<div
		data-slot="dropdown-menu-separator"
		class={ dropdownMenuSeparatorVariants(args.Class) }
		role="separator"
		{ args.Attributes... }
	></div>
}

// DropdownMenuShortcut renders keyboard shortcut text
templ DropdownMenuShortcut(args DropdownMenuShortcutArgs) {
	<span
		data-slot="dropdown-menu-shortcut"
		class={ dropdownMenuShortcutVariants(args.Class) }
		{ args.Attributes... }
	>
		{ children... }
	</span>
}

// DropdownMenuGroup renders a logical grouping of menu items
templ DropdownMenuGroup(args DropdownMenuGroupArgs) {
	<div
		data-slot="dropdown-menu-group"
		class={ dropdownMenuGroupVariants(args.Class) }
		role="group"
		{ args.Attributes... }
	>
		{ children... }
	</div>
}
