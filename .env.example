# Optional YAML config path. Defaults to the user config path when unset.
VAMOS_CONFIG=/absolute/path/to/config.yml

# Runtime overrides.
VAMOS_THOUGHTS_REPO=/absolute/path/to/host-repo
VAMOS_THOUGHTS_ROOT=/absolute/path/to/host-repo/thoughts
VAMOS_DATABASE_PATH=~/.local/state/vamos/agents.db
VAMOS_LISTEN_ADDRESS=:4200
VAMOS_PUBLIC_BASE_URL=http://localhost:4200

# Auth/deploy secrets supplied by the host. Local quickstart uses a Google OAuth
# web client with http://localhost:4200/auth/google/callback and one
# AUTH_WHITELISTED_EMAILS entry. Use AUTH_ALLOWED_DOMAINS for team deployments.
GOOGLE_CREDENTIALS_FILE=/absolute/path/to/google-client-secret.json
AUTH_ALLOWED_DOMAINS=
AUTH_WHITELISTED_EMAILS=developer@example.com
WEBHOOK_SECRET=change-me
VAMOS_INTERNAL_TOKEN=change-me

# Optional licensed static asset source. If unset, build checks
# ../datastar-pro/datastar-pro-v1.js. If no Pro asset is present, the browser
# uses public Datastar plus /js/vamos-datastar-polyfills.js.
VAMOS_DATASTAR_PRO_ASSET=
