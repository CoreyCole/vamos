package agentchat

import "fmt"

templ WorkspaceMinimap(state WorkspaceMinimapState) {
	<div id="agent-chat-workspace-minimap" class="flex h-full min-h-0 flex-col overflow-hidden">
		<div class="border-b border-border px-4 py-3">
			<p class="text-sm font-semibold text-foreground">Workspace minimap</p>
			<p class="text-xs text-muted-foreground">Semantic event trace across this workspace</p>
		</div>
		<div class="min-h-0 flex-1 overflow-y-auto p-4">
			if len(state.Events) == 0 {
				<div class="rounded-lg border border-dashed border-border p-4 text-sm text-muted-foreground">No workspace events yet.</div>
			} else {
				<ol class="relative space-y-3 border-l border-border pl-4">
					for _, event := range state.Events {
						<li class="relative">
							<span class="absolute -left-[1.35rem] top-1.5 h-2.5 w-2.5 rounded-full border border-border bg-background"></span>
							<div class="rounded-lg border border-border bg-background/50 p-3">
								<div class="flex items-start justify-between gap-3">
									<div class="min-w-0">
										<p class="truncate text-sm font-medium text-foreground">{ event.Label }</p>
										<p class="text-[11px] uppercase tracking-wide text-muted-foreground">{ event.Category }</p>
									</div>
									<time class="shrink-0 text-[11px] text-muted-foreground">{ formatWorkspaceEventTime(event.CreatedAt) }</time>
								</div>
								<div class="mt-2 flex flex-wrap gap-1 text-[11px] text-muted-foreground">
									if event.ThreadID != "" {
										<span class="rounded-full bg-muted px-2 py-0.5">thread</span>
									}
									if event.RunID != "" {
										<span class="rounded-full bg-muted px-2 py-0.5">run</span>
									}
									if event.SessionID != "" {
										<span class="rounded-full bg-muted px-2 py-0.5">session</span>
									}
									if event.CommentID != "" {
										<span class="rounded-full bg-muted px-2 py-0.5">comment</span>
									}
								</div>
							</div>
						</li>
					}
				</ol>
			}
		</div>
	</div>
}

templ WorkspaceWorkflowPanel(state WorkspaceWorkflowState) {
	<div id="agent-chat-workspace-workflow" class="flex h-full min-h-0 flex-col overflow-hidden">
		<div class="border-b border-border px-4 py-3">
			<p class="text-sm font-semibold text-foreground">Workflow</p>
			<p class="text-xs text-muted-foreground">{ string(state.Type) }</p>
		</div>
		<div class="min-h-0 flex-1 space-y-4 overflow-y-auto p-4">
			if state.Type == WorkspaceWorkflowQRSPI {
				<div class="rounded-lg border border-border bg-background/50 p-3">
					<p class="mb-2 text-xs font-medium uppercase tracking-wide text-muted-foreground">Workflow config</p>
					<form data-on:submit={ workflowPolicyAction(state) }>
						<label class="flex items-center gap-2 text-sm">
							<input type="checkbox" name="autoMode" checked?={ state.Policy.AutoMode } disabled?={ !state.Policy.Editable }/>
							<span>Auto-continue safe gates</span>
						</label>
						<label class="mt-2 flex items-center gap-2 text-sm">
							<input type="checkbox" name="enablePlanReviews" checked?={ state.Policy.EnablePlanReviews } disabled?={ !state.Policy.Editable }/>
							<span>Run planning reviews</span>
						</label>
						<label class="mt-2 block text-xs text-muted-foreground">Invalid XML retries</label>
						<input class="mt-1 w-20 rounded-md border border-input bg-background px-2 py-1 text-sm" type="number" min="0" name="invalidResultRetryLimit" value={ fmt.Sprintf("%d", state.Policy.InvalidResultRetryLimit) } disabled?={ !state.Policy.Editable }/>
						<p class="mt-2 text-xs text-muted-foreground">{ state.Policy.TimingCopy }</p>
						<p class="mt-1 text-xs text-muted-foreground">Final implementation review always waits for you.</p>
						if state.Policy.Editable {
							<button type="submit" class="mt-3 rounded-md bg-primary px-3 py-1.5 text-sm font-medium text-primary-foreground hover:bg-primary/90">Save config</button>
						}
					</form>
				</div>
				<div class={ "rounded-lg border p-3", templ.KV("border-destructive/40 bg-destructive/5", state.ActiveCwd.Blocked), templ.KV("border-border bg-background/50", !state.ActiveCwd.Blocked) }>
					<p class="mb-2 text-xs font-medium uppercase tracking-wide text-muted-foreground">Active cwd</p>
					<p class="break-words text-sm text-foreground">{ state.ActiveCwd.Label }</p>
					<p class="break-words text-xs text-muted-foreground">{ state.ActiveCwd.Path }</p>
					if state.ActiveCwd.Blocked {
						<p class="mt-2 text-xs text-destructive">{ state.ActiveCwd.BlockReason }</p>
					}
				</div>
			}
			<div class="grid grid-cols-1 gap-3 text-sm sm:grid-cols-2">
				@WorkflowStat("Current step", state.CurrentStep)
				@WorkflowStat("Status", state.Status)
				@WorkflowStat("Review gate", state.ReviewGate)
				@WorkflowStat("Type", string(state.Type))
			</div>
			if state.WaitingHuman {
				<div class="rounded-lg border border-amber-500/30 bg-amber-500/10 p-3">
					<p class="text-sm font-medium text-foreground">Human review required</p>
					if state.HumanGateReason != "" {
						<p class="mt-1 text-xs text-muted-foreground">{ state.HumanGateReason }</p>
					}
					<form class="mt-3" data-on:submit={ workflowAdvanceAction(state) }>
						<button type="submit" class="rounded-md bg-primary px-3 py-1.5 text-sm font-medium text-primary-foreground hover:bg-primary/90">Approve and continue</button>
					</form>
				</div>
			}
			if state.LastResultSummary != "" || state.PrimaryArtifact != "" || state.NextDisplay != "" {
				<div class="rounded-lg border border-border bg-background/50 p-3">
					<p class="mb-2 text-xs font-medium uppercase tracking-wide text-muted-foreground">Last result</p>
					if state.LastResultSummary != "" {
						<p class="text-sm text-foreground">{ state.LastResultSummary }</p>
					}
					if state.PrimaryArtifact != "" {
						<p class="mt-2 break-words text-xs text-muted-foreground">
							Artifact:
							<a class="text-primary underline-offset-2 hover:underline" href={ workspaceArtifactHref(state.WorkspaceID, state.PrimaryArtifact) }>{ state.PrimaryArtifact }</a>
						</p>
					}
					if state.NextDisplay != "" {
						<p class="mt-2 break-words text-xs text-muted-foreground">Next: { state.NextDisplay }</p>
					}
				</div>
			}
			if len(state.BypassedNodes) > 0 {
				<div class="rounded-lg border border-border bg-background/50 p-3">
					<p class="mb-2 text-xs font-medium uppercase tracking-wide text-muted-foreground">Bypassed nodes</p>
					<div class="flex flex-wrap gap-1">
						for _, node := range state.BypassedNodes {
							<span class="rounded-full bg-muted px-2 py-0.5 text-[11px] text-muted-foreground">{ node }</span>
						}
					</div>
				</div>
			}
			if state.Mermaid != "" {
				<div class="rounded-lg border border-border bg-background/50 p-3">
					<p class="mb-2 text-xs font-medium uppercase tracking-wide text-muted-foreground">Mermaid</p>
					<pre class="overflow-x-auto whitespace-pre-wrap text-xs text-muted-foreground"><code>{ state.Mermaid }</code></pre>
				</div>
			}
			if len(state.Metadata) > 0 {
				<div class="rounded-lg border border-border bg-background/50 p-3">
					<p class="mb-2 text-xs font-medium uppercase tracking-wide text-muted-foreground">Metadata</p>
					<pre class="overflow-x-auto whitespace-pre-wrap text-xs text-muted-foreground"><code>{ string(state.Metadata) }</code></pre>
				</div>
			}
		</div>
	</div>
}

templ WorkflowStat(label string, value string) {
	<div class="rounded-lg border border-border bg-background/50 p-3">
		<p class="text-[11px] uppercase tracking-wide text-muted-foreground">{ label }</p>
		if value == "" {
			<p class="mt-1 text-sm text-muted-foreground">—</p>
		} else {
			<p class="mt-1 text-sm font-medium text-foreground">{ value }</p>
		}
	</div>
}
