package agentchat

import (
	"fmt"
	"strconv"

	"github.com/CoreyCole/vamos/pkg/agents/chatsession"
	localsheet "github.com/CoreyCole/vamos/pkg/datastarui/components/sheet"
	localutils "github.com/CoreyCole/vamos/pkg/datastarui/utils"
	"github.com/CoreyCole/vamos/server/layouts/workbench"
)

templ SidebarToggleButton() {
	@WorkbenchRegionToggleButton("agentChatNavigation", "Toggle sessions sidebar", SidebarIcon())
}

templ NewChatButton() {
	<a
		href="/agent-chat"
		data-on:click="$agent_chat_thread_sheet.open = false"
		class="inline-flex h-8 w-8 items-center justify-center rounded-md border border-border text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
		aria-label="New chat"
		title="New chat"
	>
		<span class="sr-only">New chat</span>
		<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 5v14M5 12h14"></path>
		</svg>
	</a>
}

templ ThreadSidebar(args ThreadSidebarArgs) {
	@AgentChatSidebarTarget(AgentChatSidebarTargetArgs{
		ID:                "agent-chat-thread-sidebar",
		Body:              ThreadSidebarBody(args),
		DrawerTitle:       "Agent Chat sessions",
		HasSelectedThread: args.HasSelectedThread,
	})
}

templ WorkspaceSidebar(state WorkspaceSidebarState) {
	@AgentChatSidebarTarget(AgentChatSidebarTargetArgs{
		ID:                "agent-chat-workspace-sidebar",
		Body:              WorkspaceSidebarBody(state),
		DrawerTitle:       "Workspace sessions",
		HasSelectedThread: state.HasSelection,
	})
}

templ PlanSidebar(state PlanSidebarState) {
	@AgentChatSidebarTarget(AgentChatSidebarTargetArgs{
		ID:                planSidebarTargetID(state),
		Body:              PlanSidebarBody(state),
		DrawerTitle:       planSidebarDrawerTitle(state),
		HasSelectedThread: state.HasSelection,
	})
}

templ WorkspaceTopologySidebar(state WorkspaceSidebarProjection) {
	@AgentChatSidebarTarget(AgentChatSidebarTargetArgs{
		ID:                "agent-chat-workspace-topology-sidebar",
		Body:              WorkspaceTopologySidebarBody(state),
		DrawerTitle:       "Workspace topology",
		HasSelectedThread: len(state.Workspaces) > 0,
	})
}

templ AgentChatSidebarTarget(args AgentChatSidebarTargetArgs) {
	<div id={ args.ID } class="contents">
		@AgentChatDesktopSidebar(args.HasSelectedThread, args.Body)
		@AgentChatMobileSidebarSheet(args.DrawerTitle, args.Body)
	</div>
}

templ AgentChatDesktopSidebar(hasSelectedThread bool, body templ.Component) {
	<aside class="hidden h-full min-h-0 w-full max-w-full overflow-hidden md:block">
		<div class="flex h-full min-h-0 min-w-0 flex-col rounded-lg border border-border bg-card">
			<div class="border-b p-3">
				<div class="flex items-center gap-2">
					@SidebarToggleButton()
					@NewChatButton()
				</div>
			</div>
			<div class="min-h-0 flex-1 overflow-y-auto p-2">
				@body
			</div>
		</div>
	</aside>
}

templ ThreadSidebarBody(args ThreadSidebarArgs) {
	if len(args.Groups) == 0 {
		<p class="px-3 py-2 text-sm text-muted-foreground">No sessions yet.</p>
	} else {
		for _, group := range args.Groups {
			<section class="pb-3 last:pb-0">
				<div class="px-3 pb-2 pt-1">
					<p class="text-[10px] font-semibold uppercase tracking-wide text-muted-foreground">{ group.KindLabel }</p>
					<p class="mt-1 truncate text-xs font-medium text-foreground">{ group.Label }</p>
				</div>
				<div class="space-y-1">
					for _, thread := range group.Threads {
						@ThreadSidebarThreadRow(thread)
					}
				</div>
			</section>
		}
	}
}

templ PlanSidebarBody(state PlanSidebarState) {
	if len(state.Nodes) == 0 {
		<p class="px-3 py-2 text-sm text-muted-foreground">No plan workspaces yet.</p>
	} else {
		<div class="space-y-1">
			for _, node := range state.Nodes {
				@PlanSidebarNodeRow(state, node)
			}
		</div>
	}
}

templ WorkspaceTopologySidebarBody(state WorkspaceSidebarProjection) {
	if len(state.Workspaces) == 0 {
		<p class="px-3 py-2 text-sm text-muted-foreground">No workspaces yet.</p>
	} else {
		<div class="space-y-2">
			for _, workspace := range state.Workspaces {
				@WorkspaceTopologyWorkspaceRow(workspace)
			}
		</div>
	}
}

templ WorkspaceTopologyWorkspaceRow(workspace WorkspaceTree) {
	<section class="rounded-lg border border-border bg-background/50 p-2">
		<a href={ templ.SafeURL(workspace.Lifecycle.Href) } class="flex items-start gap-2 rounded-md px-1 py-1 transition-colors hover:bg-muted/60">
			<span class={ "mt-0.5 inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-full border text-[10px] font-semibold", workspaceLifecycleBadgeClass(workspace.Lifecycle) }>{ fmt.Sprintf("%d", workspace.Lifecycle.Progress) }</span>
			<span class="min-w-0 flex-1">
				<span class="block truncate text-xs font-medium text-foreground">{ workspace.Title }</span>
				<span class="mt-1 flex flex-wrap items-center gap-1 text-[10px] text-muted-foreground">
					<span class="rounded border border-border px-1 py-0.5 uppercase tracking-wide">{ workspace.Lifecycle.Label }</span>
					if workspace.Lifecycle.NeedsHuman {
						<span class="rounded bg-amber-500/10 px-1 py-0.5 text-amber-600">Needs human</span>
					}
					if workspace.Lifecycle.Blocked {
						<span class="rounded bg-destructive/10 px-1 py-0.5 text-destructive">Blocked</span>
					}
				</span>
			</span>
		</a>
		if workspace.Expanded && len(workspace.Nodes) > 0 {
			<div class="mt-2 space-y-1 border-l border-border pl-2">
				for _, node := range workspace.Nodes {
					@WorkspaceTopologyNodeRow(node)
				}
			</div>
		}
	</section>
}

templ WorkspaceTopologyNodeRow(node chatsession.WorkspaceTreeNode) {
	<a
		href={ templ.SafeURL(node.ChatHref) }
		class={
			"block rounded-md border px-2 py-1.5 text-xs transition-colors",
			planSidebarDepthPaddingClass(node.Depth),
			templ.KV("border-primary/30 bg-primary/5 text-foreground", node.ActivePath || node.Selected),
			templ.KV("border-transparent text-muted-foreground hover:bg-muted/60 hover:text-foreground", !node.ActivePath && !node.Selected),
		}
	>
		<span class="flex min-w-0 items-center gap-2">
			<span class="truncate font-medium">{ node.Label }</span>
			if node.Branch {
				<span class="rounded border border-border px-1 py-0.5 text-[9px] uppercase tracking-wide">Branch</span>
			}
			if node.UnresolvedCount > 0 {
				<span class="rounded bg-amber-500/10 px-1 py-0.5 text-[9px] font-semibold text-amber-600">{ fmt.Sprintf("%d unresolved", node.UnresolvedCount) }</span>
			} else if node.AnnotationCount > 0 {
				<span class="rounded bg-muted px-1 py-0.5 text-[9px]">{ fmt.Sprintf("%d notes", node.AnnotationCount) }</span>
			}
		</span>
		if node.Summary != "" {
			<span class="mt-0.5 block line-clamp-2 text-[10px] text-muted-foreground">{ node.Summary }</span>
		}
	</a>
}

templ PlanSidebarNodeRow(state PlanSidebarState, node PlanSidebarNode) {
	<div>
		if planSidebarNodeIsLeaf(node) && node.Href != "" {
			<a
				href={ templ.SafeURL(node.Href) }
				data-on:click="$agent_chat_thread_sheet.open = false"
				class={
					"group block rounded-md border px-2 py-2 transition-colors",
					planSidebarDepthPaddingClass(node.Depth),
					templ.KV("border-primary/30 bg-background shadow-sm", node.Active),
					templ.KV("border-transparent hover:bg-muted/60", !node.Active),
				}
			>
				@PlanSidebarNodeContent(node)
			</a>
			@PlanSidebarQRSPIStartControls(node)
		} else {
			<div
				class={
					"group flex items-start gap-2 rounded-md border px-2 py-2 transition-colors",
					planSidebarDepthPaddingClass(node.Depth),
					templ.KV("border-primary/30 bg-background shadow-sm", node.Active),
					templ.KV("border-transparent hover:bg-muted/60", !node.Active),
				}
				data-class={ "{'bg-background shadow-sm': " + planSidebarNodeOpenExpression(node) + ", 'bg-transparent shadow-none': !" + planSidebarNodeOpenExpression(node) + " && " + strconv.FormatBool(!node.Active) + "}" }
			>
				<div class="min-w-0 flex-1">
					if node.Href != "" {
						<a href={ templ.SafeURL(node.Href) } data-on:click="$agent_chat_thread_sheet.open = false" class="block min-w-0">
							@PlanSidebarNodeContent(node)
						</a>
					} else {
						<div class="min-w-0">
							@PlanSidebarNodeContent(node)
						</div>
					}
				</div>
				if len(node.Children) > 0 {
					<button
						type="button"
						class="mt-0.5 inline-flex h-5 w-5 shrink-0 items-center justify-center rounded border border-border text-[10px] text-muted-foreground transition-colors hover:bg-background hover:text-foreground"
						data-on:click={ planSidebarNodeSetExpression(node) }
						data-attr:aria-expanded={ planSidebarNodeOpenExpression(node) + " ? 'true' : 'false'" }
						aria-label="Toggle sub workspaces"
					>
						<span data-show={ "!" + planSidebarNodeOpenExpression(node) }>▸</span>
						<span data-show={ planSidebarNodeOpenExpression(node) }>▾</span>
					</button>
				}
			</div>
		}
		if len(node.Children) > 0 {
			<div data-show={ planSidebarNodeOpenExpression(node) } class="space-y-1 pt-1">
				for _, child := range node.Children {
					@PlanSidebarNodeRow(state, child)
				}
			</div>
		}
	</div>
}

templ PlanSidebarQRSPIStartControls(node PlanSidebarNode) {
	<form
		action="/agent-chat/plan-workspace"
		method="get"
		class={
			"mt-1 rounded-lg border border-border bg-background/50 p-3",
			planSidebarDepthPaddingClass(node.Depth),
		}
	>
		<input type="hidden" name="plan_dir" value={ node.PlanDir }/>
		<p class="text-[10px] font-semibold uppercase tracking-wide text-muted-foreground">QRSPI operating mode</p>
		<label class="mt-2 flex items-start gap-2 text-xs text-foreground">
			<input class="mt-0.5" type="radio" name="policy_preset" value="manual" checked/>
			<span><span class="font-medium">Manual</span><span class="block text-[10px] text-muted-foreground">Stop at human gates; run planning reviews.</span></span>
		</label>
		<label class="mt-2 flex items-start gap-2 text-xs text-foreground">
			<input class="mt-0.5" type="radio" name="policy_preset" value="assisted"/>
			<span><span class="font-medium">Assisted</span><span class="block text-[10px] text-muted-foreground">Auto-continue safe gates; final implementation review still waits.</span></span>
		</label>
		<label class="mt-2 flex items-start gap-2 text-xs text-foreground">
			<input class="mt-0.5" type="radio" name="policy_preset" value="fast_draft"/>
			<span><span class="font-medium">Fast draft</span><span class="block text-[10px] text-muted-foreground">Skip planning reviews for exploratory drafts; final implementation review still waits.</span></span>
		</label>
		<div class="mt-3 flex flex-wrap gap-2">
			<button type="submit" name="workflow_type" value="qrspi" class="rounded-md bg-primary px-3 py-1.5 text-xs font-medium text-primary-foreground hover:bg-primary/90">Start QRSPI</button>
			<button type="submit" name="workflow_type" value="qrspi-project-planning" class="rounded-md border border-border px-3 py-1.5 text-xs font-medium text-foreground hover:bg-muted">Start project planning</button>
		</div>
	</form>
}

templ PlanSidebarNodeContent(node PlanSidebarNode) {
	<div class="flex min-w-0 items-center gap-2">
		<p class="truncate text-xs font-medium text-foreground">{ node.Label }</p>
		if node.Active {
			<span class="shrink-0 rounded-full bg-primary/10 px-1.5 py-0.5 text-[9px] font-semibold uppercase tracking-wide text-primary">Current</span>
		}
	</div>
	<div class="mt-1 flex min-w-0 flex-wrap items-center gap-x-2 gap-y-1 text-[10px] text-muted-foreground">
		if node.LatestSourceLabel != "" {
			<span class="shrink-0 rounded border border-border px-1 py-0.5 font-medium uppercase tracking-wide">{ node.LatestSourceLabel }</span>
		}
		if node.PrimaryProject != "" {
			<span class="shrink-0 rounded border border-primary/30 bg-primary/5 px-1 py-0.5 font-medium text-primary">Primary: { node.PrimaryProject }</span>
		}
		for _, project := range node.RelatedProjects {
			<span class="shrink-0 rounded border border-border px-1 py-0.5">Related: { project }</span>
		}
		if node.MatchedRole != "" {
			<span class="shrink-0 rounded border border-border px-1 py-0.5 uppercase tracking-wide">{ node.MatchedRole } match</span>
		}
		for _, binding := range node.Bindings {
			<span class="shrink-0 rounded border border-border px-1 py-0.5">{ binding.ProjectID }: { binding.Status }</span>
		}
		if planSidebarTimestampLabel(node) != "" {
			<span class="truncate">{ planSidebarTimestampLabel(node) }</span>
		}
		if node.AggregateCount > 0 {
			<span class="shrink-0">{ planSidebarCountLabel(node) }</span>
		}
	</div>
}

templ AgentChatMobileSidebarTrigger() {
	<button
		type="button"
		class="inline-flex h-8 items-center gap-2 rounded-md border border-border px-3 text-xs font-medium text-muted-foreground transition-colors hover:bg-muted hover:text-foreground md:hidden"
		data-on:click="$agent_chat_thread_sheet.open = true"
		data-attr:aria-expanded="$agent_chat_thread_sheet.open ? 'true' : 'false'"
		aria-controls={ agentChatThreadSheetID }
		aria-label="Open sessions drawer"
		title="Open sessions drawer"
	>
		<svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16"></path>
		</svg>
		<span>Sessions</span>
	</button>
}

templ AgentChatMobileSidebarSheet(title string, body templ.Component) {
	{{
		signals := localutils.Signals(agentChatThreadSheetID, localsheet.SheetSignals{})
		sheetHandler := localsheet.NewSheetHandler(signals)
		backdropDataClass := localutils.NewDataClass().
			Add("block opacity-100", signals.Signal("open")).
			Add("hidden opacity-0", "!"+signals.Signal("open")).
			Build()
		panelDataClass := localutils.NewDataClass().
			Add("block opacity-100", signals.Signal("open")).
			Add("hidden opacity-0", "!"+signals.Signal("open")).
			Build()
	}}
	<div class="md:hidden">
		<div
			data-show={ signals.Signal("open") }
			data-class={ backdropDataClass }
			data-on:click={ sheetHandler.BuildBackdropClickHandler() }
			class="fixed inset-0 z-50 hidden bg-black/50 transition-opacity duration-300"
			aria-hidden="true"
		></div>
		<div
			id={ agentChatThreadSheetID }
			data-show={ signals.Signal("open") }
			data-class={ panelDataClass }
			class="fixed inset-y-0 left-0 z-50 hidden h-full w-3/4 border-r border-border bg-background shadow-lg transition-opacity duration-300 sm:max-w-sm"
			role="dialog"
			aria-modal="true"
			aria-labelledby="agent_chat_thread_sheet_title"
			tabindex="-1"
			data-on:keydown__window={ sheetHandler.BuildEscapeHandler() }
			data-init="el.focus()"
		>
			<div class="flex h-full min-h-0 flex-col">
				<div class="flex items-center justify-between gap-3 border-b p-3">
					<div class="min-w-0">
						<p id="agent_chat_thread_sheet_title" class="truncate text-sm font-semibold text-foreground">{ title }</p>
						<p class="text-xs text-muted-foreground">Choose a session or start a new chat</p>
					</div>
					<div class="flex shrink-0 items-center gap-2">
						@NewChatButton()
					</div>
				</div>
				<div class="min-h-0 flex-1 overflow-y-auto p-2">
					@body
				</div>
			</div>
		</div>
	</div>
}

templ RunHeader(state workbench.WorkbenchState) {
	@FreeformRunHeader(state)
}

templ WorkspaceSidebarBody(state WorkspaceSidebarState) {
	if len(state.Groups) == 0 {
		<p class="px-3 py-2 text-sm text-muted-foreground">No sessions yet.</p>
	} else {
		for _, group := range state.Groups {
			@WorkspaceSidebarGroup(state, group)
		}
	}
}

templ WorkspaceSidebarGroup(state WorkspaceSidebarState, group ThreadSidebarGroup) {
	<section class="pb-3 last:pb-0">
		<div
			class={
				"flex items-start gap-2 rounded-md border px-2 pb-2 pt-1 transition-colors",
				templ.KV("border-primary/30 bg-background shadow-sm", group.IsActive),
				templ.KV("border-transparent hover:bg-muted/60", !group.IsActive),
			}
			data-class={ "{'bg-background shadow-sm': " + workspaceSidebarGroupOpenExpression(group) + ", 'bg-transparent shadow-none': !" + workspaceSidebarGroupOpenExpression(group) + " && " + strconv.FormatBool(!group.IsActive) + "}" }
		>
			<button
				type="button"
				class="flex min-w-0 flex-1 items-start gap-2 text-left"
				data-on:click={ workspaceSidebarGroupSetExpression(group) }
				data-attr:aria-expanded={ workspaceSidebarGroupOpenExpression(group) + " ? 'true' : 'false'" }
			>
				<span
					class={
						"mt-3 inline-flex h-6 w-7 shrink-0 items-center justify-center rounded border px-1 text-[10px] font-medium",
						templ.KV("border-primary/40 bg-primary/10 text-primary", group.IsActive),
						templ.KV("border-border text-muted-foreground", !group.IsActive),
					}
					data-class={ "{'bg-background text-foreground': " + workspaceSidebarGroupOpenExpression(group) + "}" }
				>
					{ fmt.Sprintf("%d", group.ThreadCount) }
				</span>
				<div class="min-w-0 flex-1">
					<div class="flex items-center gap-2">
						<p class="truncate text-[10px] font-semibold uppercase tracking-wide text-muted-foreground">{ group.KindLabel }</p>
						if group.IsActive {
							<span class="rounded-full bg-primary/10 px-1.5 py-0.5 text-[9px] font-semibold uppercase tracking-wide text-primary">Current</span>
						}
					</div>
					<p class="mt-1 truncate text-xs font-medium text-foreground">{ group.Label }</p>
					if group.Timestamp != "" {
						<p class="mt-0.5 truncate text-[10px] text-muted-foreground">{ group.Timestamp }</p>
					}
				</div>
			</button>
			if group.WorkspaceHref != "" && !group.IsActive {
				<a href={ templ.SafeURL(group.WorkspaceHref) } class="mt-3 inline-flex h-6 w-6 shrink-0 items-center justify-center rounded border border-border text-xs text-muted-foreground transition-colors hover:bg-background hover:text-foreground" title="Open workspace" aria-label="Open workspace">↗</a>
			}
		</div>
		<div data-show={ workspaceSidebarGroupOpenExpression(group) } class="max-h-56 space-y-1 overflow-y-auto pt-1">
			for _, thread := range group.Threads {
				@WorkspaceSidebarThreadRow(state.WorkspaceID, thread)
			}
		</div>
	</section>
}

templ ThreadSidebarThreadRow(thread ThreadSidebarThread) {
	if thread.Href != "" {
		<a
			href={ templ.SafeURL(thread.Href) }
			data-on:click="$agent_chat_thread_sheet.open = false"
			class={
				"block rounded-md px-3 py-2 text-sm transition-colors",
				templ.KV("bg-accent text-accent-foreground", thread.IsActive),
				templ.KV("text-muted-foreground hover:bg-muted hover:text-foreground", !thread.IsActive),
			}
		>
			@WorkspaceSidebarThreadContent(thread)
		</a>
	} else if thread.OpenPiSessionAction != "" {
		@PiSessionOpenSidebarForm(
			thread,
			"w-full rounded-md px-3 py-2 text-left text-sm text-muted-foreground transition-colors hover:bg-muted hover:text-foreground disabled:pointer-events-none disabled:opacity-70",
		)
	} else {
		<div class="rounded-md border border-border/60 bg-muted/20 px-3 py-2 text-sm text-muted-foreground">
			@WorkspaceSidebarThreadContent(thread)
		</div>
	}
}

templ WorkspaceSidebarThreadRow(workspaceID string, thread ThreadSidebarThread) {
	if thread.Href != "" {
		<a
			href={ templ.SafeURL(thread.Href) }
			data-on:click="$agent_chat_thread_sheet.open = false"
			class={
				"block w-full rounded-md px-3 py-2 text-left text-sm transition-colors",
				templ.KV("bg-accent text-accent-foreground", thread.IsActive),
				templ.KV("text-muted-foreground hover:bg-muted hover:text-foreground", !thread.IsActive),
			}
		>
			@WorkspaceSidebarThreadContent(thread)
		</a>
	} else if thread.OpenPiSessionAction != "" {
		@PiSessionOpenSidebarForm(
			thread,
			"w-full rounded-md px-3 py-2 text-left text-sm text-muted-foreground transition-colors hover:bg-muted hover:text-foreground disabled:pointer-events-none disabled:opacity-70",
		)
	} else {
		<div class="rounded-md border border-border/60 bg-muted/20 px-3 py-2 text-sm text-muted-foreground">
			@WorkspaceSidebarThreadContent(thread)
		</div>
	}
}

templ PiSessionOpenSidebarForm(thread ThreadSidebarThread, buttonClasses string) {
	{{ indicator := piSessionOpenIndicator(thread) }}
	{{ indicatorSignal := piSessionOpenIndicatorSignal(thread) }}
	<form class="block" data-on:submit={ thread.OpenPiSessionAction }>
		<input type="hidden" name="session_path" value={ thread.SessionPath }/>
		<input type="hidden" name="workspace_dir" value={ thread.WorkspaceDir }/>
		<button
			type="submit"
			class={ buttonClasses }
			data-indicator={ indicator }
			data-attr:disabled={ indicatorSignal }
		>
			<div data-show={ "!" + indicatorSignal }>
				@WorkspaceSidebarThreadContent(thread)
			</div>
			<div data-show={ indicatorSignal } class="flex items-start justify-between gap-2">
				<div class="line-clamp-2 min-w-0 flex-1">Opening…</div>
				if thread.SourceLabel != "" {
					<span class="shrink-0 rounded border border-border px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide text-muted-foreground">{ thread.SourceLabel }</span>
				}
			</div>
			if thread.CwdLabel != "" {
				<p data-show={ indicatorSignal } class="mt-1 truncate text-xs text-muted-foreground">{ thread.CwdLabel }</p>
			}
		</button>
	</form>
}

templ WorkspaceSidebarThreadContent(thread ThreadSidebarThread) {
	<div class="flex items-start justify-between gap-2">
		<div class="line-clamp-2 min-w-0 flex-1">{ thread.Title }</div>
		if thread.SourceLabel != "" {
			<span class="shrink-0 rounded border border-border px-1.5 py-0.5 text-[10px] font-medium uppercase tracking-wide text-muted-foreground">{ thread.SourceLabel }</span>
		}
	</div>
	if thread.CwdLabel != "" {
		<p class="mt-1 truncate text-xs text-muted-foreground">{ thread.CwdLabel }</p>
	}
}

templ WorkspaceHeader(projection WorkspaceProjection, state workbench.WorkbenchState) {
	{{ header := projection.Header }}
	<div
		id="agent-chat-workspace-header"
		class="absolute inset-x-0 top-0 z-20 flex items-center gap-3 border-b bg-card px-4 py-3 backdrop-blur supports-[backdrop-filter]:bg-card/95"
	>
		<div class="flex min-w-0 flex-1 items-center gap-2">
			<div
				class="hidden shrink-0 items-center gap-2"
				data-class="{'!hidden': $workbench.regions.agentChatNavigation.visible, '!flex': !$workbench.regions.agentChatNavigation.visible}"
			>
				@WorkbenchRegionToggleButton("agentChatNavigation", "Toggle sessions sidebar", SidebarIcon())
				@NewChatButton()
			</div>
			<div class="min-w-0 flex-1">
				<p class="truncate text-sm font-medium text-foreground">{ header.Title }</p>
				if header.ModelLabel != "" || header.ThinkingLabel != "" {
					<p class="truncate text-xs text-muted-foreground">
						if header.ModelLabel != "" {
							<span>{ header.ModelLabel }</span>
						}
						if header.ModelLabel != "" && header.ThinkingLabel != "" {
							<span>· </span>
						}
						if header.ThinkingLabel != "" {
							<span>{ header.ThinkingLabel }</span>
						}
					</p>
				}
			</div>
		</div>
		<div class="flex shrink-0 items-center justify-end gap-2">
			@WorkbenchRegionToggleButton("agentChatContext", "Toggle artifact pane", ArtifactIcon())
			@WorkbenchFocusToggleButton(state)
			@WorkbenchResetLayoutButton(state)
		</div>
	</div>
}
