package agentchat

templ QRSPIWorkflowCardView(card QRSPIWorkflowCard) {
	<div class="border-b border-border bg-background/70 px-4 py-3">
		<article class="rounded-xl border border-border bg-card p-4 shadow-sm">
			<div class="flex items-start justify-between gap-3">
				<div>
					<p class="text-sm font-semibold text-foreground">QRSPI { card.Stage } complete</p>
					<p class="text-xs text-muted-foreground">Outcome: { card.Outcome } · Status: { card.Status }</p>
				</div>
				if card.WaitingHuman {
					<span class="rounded-full bg-amber-500/10 px-2 py-0.5 text-xs text-amber-600">Waiting for you</span>
				}
			</div>
			if card.Summary != "" {
				<p class="mt-3 text-sm text-foreground">{ card.Summary }</p>
			}
			<div class="mt-3 grid gap-2 text-xs text-muted-foreground">
				if card.PrimaryArtifact != "" {
					<a class="break-words text-primary underline-offset-2 hover:underline" href={ workspaceArtifactHref(card.WorkspaceID, card.PrimaryArtifact) }>Artifact: { card.PrimaryArtifact }</a>
				}
				if card.RuntimeNextStep != "" {
					<p>Next stage: <span class="text-foreground">{ card.RuntimeNextStep }</span></p>
				}
				<p>Cwd: <span class="text-foreground">{ card.Cwd.Label }</span> · { card.Cwd.Scope }</p>
				<p>Policy: { card.Policy.ModeLabel } · { card.Policy.ReviewLabel } · { card.Policy.RetryLabel }</p>
			</div>
			if card.WaitingHuman {
				<form class="mt-3" data-on:submit={ "@post('/agent-chat/" + card.WorkspaceID + "/workflow/advance', {contentType: 'form'})" }>
					<button type="submit" class="rounded-md bg-primary px-3 py-1.5 text-sm font-medium text-primary-foreground hover:bg-primary/90">Proceed</button>
				</form>
			}
			if card.RawXML != "" {
				<details class="mt-3">
					<summary class="cursor-pointer text-xs text-muted-foreground">Show raw workflow result</summary>
					<pre class="mt-2 overflow-x-auto whitespace-pre-wrap rounded-md bg-muted p-2 text-xs text-muted-foreground"><code>{ card.RawXML }</code></pre>
				</details>
			}
		</article>
	</div>
}
