package markdown

templ HTMLAppletFrame(docPath string, src string) {
	<section class="flex h-full min-h-0 w-full flex-1 flex-col">
		<iframe
			data-vamos-html-applet
			title={ "HTML applet " + docPath }
			src={ templ.SafeURL(src) }
			sandbox="allow-scripts allow-forms allow-downloads"
			class="h-full min-h-0 w-full flex-1 border-0 bg-background"
			referrerpolicy="same-origin"
		></iframe>
	</section>
}
