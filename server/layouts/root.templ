templ HeaderBrand(args RootArgs) {
	<a class="flex items-center no-underline" href="/">
		<span class="font-semibold text-foreground">{ AppName() }</span>
	</a>
}

templ HeaderVisibleProductNav(args RootArgs, items []headerNavItem) {
	<nav class="flex items-center gap-3" aria-label="Product navigation">
		for _, item := range items {
			@HeaderProductNavItem(args, item)
		}
	</nav>
}

templ HeaderProductNavItem(args RootArgs, item headerNavItem) {
	{{ active := headerNavItemActive(args.PageType, item) }}
	<a
		class={
			"text-sm no-underline transition-colors",
			templ.KV("text-foreground font-medium", active),
			templ.KV("text-muted-foreground hover:text-foreground", !active),
		}
		href={ templ.SafeURL(item.Href) }
	>
		{ item.Label }
	</a>
}

// buildBreadcrumbsFromPath creates breadcrumb items from a file path and page type.
func buildBreadcrumbsFromPath(rawPath string, pageType PageType, chat BreadcrumbLinkState) []breadcrumb.BreadcrumbItemData {
	cleaned := cleanThoughtsBreadcrumbPath(rawPath)
	if cleaned == "" {
		return nil
	}

	parts := strings.Split(cleaned, "/")
	items := make([]breadcrumb.BreadcrumbItemData, 0, len(parts))
	for i := range parts {
		isLast := i == len(parts)-1
		href := ""
		if !isLast {
			href = thoughtsBreadcrumbHref(cleaned, parts, i, pageType, chat)
		}
		items = append(items, breadcrumb.BreadcrumbItemData{
			Label: formatBreadcrumbLabelForPathPart(parts, i),
			Href:  href,
		})
	}
	return items
}

func cleanThoughtsBreadcrumbPath(rawPath string) string {
	cleaned := strings.TrimSpace(rawPath)
	cleaned = strings.TrimPrefix(cleaned, "/")
	cleaned = strings.TrimPrefix(cleaned, "thoughts/")
	cleaned = strings.Trim(cleaned, "/")
	cleaned = strings.TrimSuffix(cleaned, ".md")
	return cleaned
}

func thoughtsBreadcrumbHref(
	currentPath string,
	parts []string,
	index int,
	pageType PageType,
	chat BreadcrumbLinkState,
) string {
	_ = currentPath
	_ = pageType
	if index < 0 || index >= len(parts) {
		return breadcrumbPreserveChat("/thoughts/", chat)
	}
	joined := strings.Join(parts[:index+1], "/")
	if strings.TrimSpace(joined) == "" {
		return breadcrumbPreserveChat("/thoughts/", chat)
	}
	return breadcrumbPreserveChat("/thoughts/"+joined, chat)
}

func breadcrumbPreserveChat(href string, chat BreadcrumbLinkState) string {
	if !chat.Active {
		return href
	}
	values := []string{"context=chat"}
	threadID := strings.TrimSpace(chat.ThreadID)
	if threadID == "" {
		if workspaceID := strings.TrimSpace(chat.WorkspaceID); workspaceID != "" {
			values = append(values, "chat_workspace="+url.QueryEscape(workspaceID))
		}
	} else {
		values = append(values, "thread="+url.QueryEscape(threadID))
	}
	if strings.TrimSpace(chat.RunID) != "" {
		values = append(values, "run="+url.QueryEscape(strings.TrimSpace(chat.RunID)))
	}
	sep := "?"
	if strings.Contains(href, "?") {
		sep = "&"
	}
	return href + sep + strings.Join(values, "&")
}

func formatBreadcrumbLabelForPathPart(parts []string, index int) string {
	part := parts[index]
	if isPlanWorkspaceNamePart(parts, index) {
		part = stripPlanWorkspaceTimestamp(part)
	}
	return formatBreadcrumbLabel(part)
}

func isPlanWorkspaceNamePart(parts []string, index int) bool {
	if index == 0 {
		return false
	}
	switch parts[index-1] {
	case "plans", "reviews", "milestones":
		return true
	default:
		return false
	}
}

func stripPlanWorkspaceTimestamp(part string) string {
	if len(part) > len("2006-01-02_15-04-05_") && part[4] == '-' && part[7] == '-' &&
		(part[10] == '_' || part[10] == '-') && part[13] == '-' && part[16] == '-' &&
		(part[19] == '_' || part[19] == '-') {
		return part[20:]
	}
	return part
}

// formatBreadcrumbLabel formats a path part into a readable breadcrumb label
func formatBreadcrumbLabel(part string) string {
	// Remove common date prefixes (e.g., "2025-09-22-PRO-7016" -> "PRO-7016")
	if len(part) > 10 && part[4] == '-' && part[7] == '-' {
		// Looks like a date prefix, remove it
		part = part[11:]
	}

	// Replace hyphens and underscores with spaces
	part = strings.ReplaceAll(part, "-", " ")
	part = strings.ReplaceAll(part, "_", " ")

	// Capitalize first letter of each word
	words := strings.Fields(part)
	for i, word := range words {
		if len(word) > 0 {
			words[i] = strings.ToUpper(word[:1]) + word[1:]
		}
	}

	return strings.Join(words, " ")
}
